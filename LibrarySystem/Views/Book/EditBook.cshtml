@using LibrarySystem.Shared.BookData
@using LibrarySystem.Helpers
@{
    ViewData["Title"] = "Books Management";
    ViewData["SubTitle"] = "Book Edit";
}
@model BookDetails
<h1>Edit Book</h1>
<form asp-controller="Book" asp-action="EditBook" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Name">Book Name<span class="text-danger">*</span></label>
                <input type="text" asp-for="Name" placeholder="Enter Book Name" class="form-control"/>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Author">Author Name<span class="text-danger">*</span></label>
                <select asp-for="Author" asp-items="Model.AuthorList" class="form-control">
                    <option value="">Select Author</option>
                </select>
                <span asp-validation-for="Author" class="text-danger"></span>
            </div>
        </div>

    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Publication">Publication<span class="text-danger">*</span></label>
                <select asp-for="Publication" asp-items="Model.PublicationList" class="form-control">
                    <option value="">Select Publication</option>
                </select>
                <span asp-validation-for="Publication" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Category">Category<span class="text-danger">*</span></label>
                <select asp-for="Category" asp-items="Model.CategoryList" class="form-control">
                    <option value="">Select Category</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Isbn">ISBN<span class="text-danger">*</span></label>
                <input type="text" asp-for="Isbn" placeholder="Enter ISBN" class="form-control"/>
                <span asp-validation-for="Isbn" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="TotalCopies">Total Copies<span class="text-danger">*</span></label>
                <input type="number" asp-for="TotalCopies" placeholder="Enter Total Copies" class="form-control"/>
                <span asp-validation-for="TotalCopies" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="AvailableCopies">Available Copies<span class="text-danger">*</span></label>
                <input type="number" asp-for="AvailableCopies" placeholder="Enter Available Copies" class="form-control"/>
                <span asp-validation-for="AvailableCopies" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Edition">Edition<span class="text-danger">*</span></label>
                <input type="text" asp-for="Edition" placeholder="Enter Edition" class="form-control"/>
                <span asp-validation-for="Edition" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Status">Status</label>
                <select asp-for="Status" class="form-control">
                    <option value="">Select Status</option>
                    <option value="A">Available</option>
                    <option value="N">Not Available</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="ImageFile">Book Cover Image</label>
                <input type="file" asp-for="ImageFile" class="form-control" accept=".jpg,.jpeg,.png" id="imageInput" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <div id="previewContainer">
                    <label class="d-block mb-1">Current/New Cover Preview:</label>
                    <div class="d-flex align-items-center gap-3">
                        <img id="imagePreview" 
                             src="@BookImageHelper.GenerateSecureImageUrl(Model.ImageUrl, Url)" 
                             alt="Cover Preview" 
                             style="max-height: 120px; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06); border: 1px solid #dee2e6;" />
                        <button type="button" class="btn btn-outline-danger btn-sm" id="btnRemoveImage" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display: none;" : "")">Remove Image</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12" style="margin-top:15px;">
            <div class="form-group">
                <input type="hidden" asp-for="BookId"/>
                <input type="hidden" asp-for="ImageUrl" id="ImageUrl"/>
                <input type="submit" value="Submit" class="btn btn-success"/>
            </div>
        </div>
    </div>
</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            $("select.form-control").select2({width: '100%'});

            const originalImage = "@BookImageHelper.GenerateSecureImageUrl(Model.ImageUrl, Url)";
            const hasOriginalImage = @(string.IsNullOrEmpty(Model.ImageUrl) ? "false" : "true");

            // Image preview logic
            $("#imageInput").change(function () {
                const file = this.files[0];
                if (file) {
                    let reader = new FileReader();
                    reader.onload = function (e) {
                        $("#imagePreview").attr("src", e.target.result);
                        $("#btnRemoveImage").show().text("Remove Upload");
                    }
                    reader.readAsDataURL(file);
                } else {
                    $("#imagePreview").attr("src", originalImage);
                    if (!hasOriginalImage) {
                        $("#btnRemoveImage").hide();
                    } else {
                        $("#btnRemoveImage").show().text("Remove Image");
                    }
                }
            });

            $("#btnRemoveImage").click(function () {
                $("#imageInput").val("");
                if ($("#ImageUrl").val() === "") {
                    // Already cleared original image, revert back to default view
                    $("#imagePreview").attr("src", "@BookImageHelper.GetBookImageView(null)");
                    $(this).hide();
                } else {
                    // Check if we are removing a newly selected upload or the original stored cover
                    const fileSelected = $("#imageInput")[0].files.length > 0;
                    if (fileSelected) {
                        $("#imageInput").val("");
                        $("#imagePreview").attr("src", originalImage);
                        if (!hasOriginalImage) {
                            $(this).hide();
                        } else {
                            $(this).text("Remove Image");
                        }
                    } else {
                        // Clear original stored cover image URL
                        $("#ImageUrl").val("");
                        $("#imagePreview").attr("src", "@BookImageHelper.GetBookImageView(null)");
                        $(this).hide();
                    }
                }
            });
        });
    </script>
