@using LibrarySystem.Shared.BookData
@using LibrarySystem.Helpers
@using LibrarySystem.Shared

@{
    ViewData["Title"] = "Books Management";
    ViewData["SubTitle"] = "Books List";
}

@model List<BookDetails>
@section Styles {
    <style>
        .table-responsive {
            margin-top: 20px;
        }
        .book-cover-thumbnail {
            width: 45px;
            height: 65px;
            object-fit: cover;
            border-radius: 6px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
            border: 1px solid rgba(0, 0, 0, 0.08);
            transition: all 0.2s ease-in-out;
        }
        .book-cover-thumbnail:hover {
            transform: scale(1.15) translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.15), 0 4px 6px -2px rgba(0,0,0,0.1);
        }
    </style>
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.8/css/dataTables.dataTables.min.css" asp-append-version="true" />
}

@{
    string tempDataMessage = TempData["isSuccess"] as string ?? string.Empty;
    if(!string.IsNullOrEmpty(tempDataMessage))
    {
        if (tempDataMessage == "YES")
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }
        else
        {
            <div class="alert alert-danger">@TempData["Message"]</div>
        }
    }
}

<a asp-controller="Book" asp-action="AddBook" class="btn btn-primary">Add Books</a>

<div class="table-responsive">
    <table class="table" id="bookTable">
        <thead>
            <tr>
                <th>SN</th>
                <th>Book Cover</th>
                <th>Book Name</th>
                <th>Book Author</th>
                <th>Book Publication</th>
                <th>Book Status</th>
                <th>Operations</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
                foreach (var book in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>
                            <img src="@BookImageHelper.GenerateSecureImageUrl(book.ImageUrl, Url)" alt="@book.Name Cover" class="book-cover-thumbnail" />
                        </td>
                        <td>@book.Name</td>
                        <td>@book.Author</td>
                        <td>@book.Publication</td>
                        <td>
                            @{
                                if (book.Status == "A")
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Not Available</span>
                                }
                            }
                        </td>
                        <td class="operations-cell">
                            <div class="table-actions">
                            <a class="btn btn-primary btn-sm" asp-controller="Book" asp-action="EditBook" asp-route-id="@book.BookId">Edit</a>
                            <a class="btn btn-warning btn-sm" asp-controller="Book" asp-action="UpdateStatus" asp-route-id="@book.BookId" onclick="return confirm('Are you sure you want to change the status?')">Change Status</a>
                            <form asp-controller="Book" asp-action="DeleteBook" asp-route-id="@book.BookId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this book?')">Delete</button>
                            </form>
                            </div>
                        </td>
                    </tr>
                    i++;
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js" asp-append-version="true"></script>
    <script>
        libraryDataTable('#bookTable');
    </script>
}
