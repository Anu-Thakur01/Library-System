@using LibrarySystem.Shared.BorrowData
@model List<BorrowDetails>
@section Styles {
    <style>
        .table-responsive {
            margin-top: 20px;
        }
    </style>
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.8/css/dataTables.dataTables.min.css" asp-append-version="true" />
}

<div class="d-flex align-items-center mb-3">
    <button type="button" class="btn btn-secondary me-2" onclick="goBack('@Url.Action("Index","Home")')">Back</button>
    <h1 class="mb-0">Borrow Management</h1>
</div>

@{
    string tempDataMessage = TempData["isSuccess"] as string ?? string.Empty;
    if(!string.IsNullOrEmpty(tempDataMessage))
    {
        if (tempDataMessage == "YES")
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }
        else
        {
            <div class="alert alert-danger">@TempData["Message"]</div>
        }
    }
}

<a asp-controller="Borrow" asp-action="Add" class="btn btn-primary">Borrow Book</a>

<div class="table-responsive">
    <table class="table" id="borrowTable">
        <thead>
        <tr>
            <th>SN</th>
            <th>Book Name</th>
            <th>Member Name</th>
            <th>Borrowed On</th>
            <th>Due Date</th>
            <th>Returned</th>
            <th>Overdue</th>
            <th>Fine (Rs.)</th>
            <th>Status</th>
            <th>Operations</th>
        </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
                foreach (var borrow in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@borrow.BookName</td>
                        <td>@borrow.MemberName</td>
                        <td>@borrow.BorrowedOn.ToString("yyyy-MM-dd")</td>
                        <td>@borrow.DueDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @{
                                if (borrow.IsReturned)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">No</span>
                                }
                            }
                        </td>
                        <td>
                            @{
                                if (borrow.IsOverdue)
                                {
                                    <span class="badge bg-danger">Yes (@borrow.DaysOverdue days)</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">No</span>
                                }
                            }
                        </td>
                        <td>@borrow.FineAmount</td>
                        <td>@borrow.Status</td>
                        <td>
                            <a class="btn btn-primary btn-sm" asp-controller="Borrow" asp-action="Details" asp-route-id="@borrow.BorrowId">View</a>
                            @if (!borrow.IsReturned)
                            {
                                <form method="post" asp-controller="Borrow" asp-action="ReturnBook" style="display:inline;">
                                    <input type="hidden" name="id" value="@borrow.BorrowId" />
                                    <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Mark as returned?')">Return</button>
                                </form>
                            }
                        </td>
                    </tr>
                    i++;
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            libraryDataTable('#borrowTable');
        });
    </script>
}
