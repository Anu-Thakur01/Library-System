@using LibrarySystem.Shared.AuthorData
@model List<AuthorDetails>

@section Styles {
    <style>
        .table-responsive {
            margin-top: 20px;
        }
    </style>
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.8/css/dataTables.dataTables.min.css" asp-append-version="true" />
}

<h1>Author Management</h1>

@{
    string tempDataMessage = TempData["isSuccess"] as string ?? string.Empty;
    if(!string.IsNullOrEmpty(tempDataMessage))
    {
        if (tempDataMessage == "YES")
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }
        else
        {
            <div class="alert alert-danger">@TempData["Message"]</div>
        }
    }
}

<a asp-controller="Author" asp-action="Add" class="btn btn-primary">Add Author</a>

<div class="table-responsive">
    <table class="table" id="authorTable">
        <thead>
        <tr>
            <th>SN</th>
            <th>Author Name</th>
            <th>Bio</th>
            <th>Date of Birth</th>
            <th>Status</th>
            <th>Operations</th>
        </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
                foreach (var author in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>
                            @{
                                var fullName = string.Concat(
                                    author.FirstName,
                                    " ",
                                    string.IsNullOrEmpty(author.MiddleName) ? string.Empty : author.MiddleName + " ",
                                    " ",
                                    author.LastName
                                );
                            }
                            @fullName
                        </td>
                        <td>@author.Bio</td>
                        <td>@author.DateOfBirth</td>
                        <td>
                            @{
                                if (author.Status == "A")
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Not Available</span>
                                }
                            }
                        </td>
                        <td class="operations-cell">
                            <div class="table-actions">
                            <a class="btn btn-primary btn-sm" asp-controller="Author" asp-action="Edit" asp-route-id="@author.AuthorId">Edit</a>
                            <a class="btn btn-warning btn-sm" asp-controller="Author" asp-action="UpdateStatus" asp-route-id="@author.AuthorId" onclick="return confirm('Are you sure you want to change the status?')">Change Status</a>
                            <form asp-controller="Author" asp-action="Delete" asp-route-id="@author.AuthorId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this author?')">Delete</button>
                            </form>
                            </div>
                        </td>
                    </tr>
                    i++;
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js" asp-append-version="true"></script>
    <script>
        libraryDataTable('#authorTable');
    </script>
}
