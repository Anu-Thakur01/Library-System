@using LibrarySystem.Shared.MemberData
@model List<MemberDetails>
@section Styles {
    <style>
        .table-responsive {
            margin-top: 20px;
        }
    </style>
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.8/css/dataTables.dataTables.min.css" asp-append-version="true" />
}

<div class="d-flex align-items-center mb-3">
    <button type="button" class="btn btn-secondary me-2" onclick="goBack('@Url.Action("Index","Home")')">Back</button>
    <h1 class="mb-0">Member Management</h1>
</div>

@{
    string tempDataMessage = TempData["isSuccess"] as string ?? string.Empty;
    if(!string.IsNullOrEmpty(tempDataMessage))
    {
        if (tempDataMessage == "YES")
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }
        else
        {
            <div class="alert alert-danger">@TempData["Message"]</div>
        }
    }
}

<a asp-controller="Member" asp-action="Add" class="btn btn-primary">Add Member</a>

<div class="table-responsive">
    <table class="table" id="memberTable">
        <thead>
            <tr>
                <th>SN</th>
                <th>Member Name</th>
                <th>Joined Date</th>
                <th>Expiry Date</th>
                <th>Member Status</th>
                <th>Operations</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
                foreach (var member in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@member.MemberName</td>
                        <td>@member.JoinedDate</td>
                        <td>@member.ExpirationDate</td>
                        <td>
                            @{
                                if (member.Status == "A")
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Not Available</span>
                                }
                            }
                        </td>
                        <td>
                            <a class="btn btn-primary btn-sm" asp-controller="Member" asp-action="Edit" asp-route-id="@member.MemberId">Edit</a>
                            <a class="btn btn-warning btn-sm" asp-controller="Member" asp-action="UpdateStatus" asp-route-id="@member.MemberId" onclick="return confirm('Are you sure you want to change the status?')">Change Status</a>
                            <form asp-controller="Member" asp-action="Delete" asp-route-id="@member.MemberId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this member?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                    i++;
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js" asp-append-version="true"></script>
    <script>
        libraryDataTable('#memberTable');
    </script>
}
